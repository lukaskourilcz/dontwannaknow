  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:content": "node scripts/build-public-data.mjs --check && node scripts/audit-content.mjs",
    "data:public": "node scripts/build-public-data.mjs",
    "fix:duplicates": "node scripts/dedupe-content.mjs",
    "check": "npm run typecheck && npm run lint && npm test && npm run audit:content && npm run build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
